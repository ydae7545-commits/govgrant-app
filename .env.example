# ============================================================================
# govgrant-app 환경변수 템플릿
# ============================================================================
# 이 파일은 템플릿입니다. 실제 값이 들어간 `.env.local` 파일은 절대 커밋하지
# 마세요 (.gitignore에서 제외됨). 로컬 개발 시:
#
#   cp .env.example .env.local
#   # 또는 Vercel에서 가져오기:
#   vercel env pull .env.local
#
# 각 변수의 상세 용도·노출 가능 여부는 docs/ENV.md 참고.
# Phase 0 키 발급 절차는 docs/SETUP.md 참고.
# ============================================================================


# ─── Supabase ───────────────────────────────────────────────────────────────
# dev/prod 프로젝트 각각의 URL + 키. NEXT_PUBLIC_ 접두어가 있으면 클라이언트 번들에
#포함되어도 안전(RLS가 데이터 접근 제어). SERVICE_ROLE_KEY는 서버 전용 — RLS 우회
# 가능하므로 클라이언트 노출 절대 금지.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# ─── LLM Providers ─────────────────────────────────────────────────────────
# Anthropic(기본) + OpenAI(폴백) 둘 다 사용. 서버 전용 키. 절대 NEXT_PUBLIC_ 금지.
# Phase 3(사업계획서 도우미) / Phase 4(RAG 챗봇·임베딩)에서 사용.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

LLM_DEFAULT_PROVIDER=anthropic
LLM_FALLBACK_PROVIDER=openai
LLM_DEFAULT_MODEL_ANTHROPIC=claude-sonnet-4-5
LLM_DEFAULT_MODEL_OPENAI=gpt-4o-mini

# 사용자당 하루 LLM 비용 상한 (USD). 비용 폭주 방지용 하드 가드.
# Phase 2의 guard.ts가 usage_events 합계와 비교하여 429 응답을 결정.
LLM_MAX_DAILY_COST_USD_PER_USER=2.00


# ─── Feature Flags ─────────────────────────────────────────────────────────
# 각 Phase 기능을 단계적으로 활성화하기 위한 플래그. 배포 후 문제 발생 시
# 코드 롤백 없이 false로 바꾸면 즉시 이전 동작으로 복귀.
# 모두 NEXT_PUBLIC_ — 클라이언트에서도 분기 처리가 필요해서.

# Phase 1: Supabase 인증/DB 활성화. true로 바꾸면 Zustand localStorage 대신 Supabase 사용.
NEXT_PUBLIC_USE_SUPABASE=false

# Phase 4: 챗봇을 키워드 매칭에서 LLM+RAG로 전환.
NEXT_PUBLIC_USE_LLM_CHAT=false

# Phase 3: AI 사업계획서 도우미 UI/API 활성화.
NEXT_PUBLIC_USE_PROPOSAL_AI=false

# Phase 4: 검색/추천에 임베딩 기반 의미 검색 활성화.
NEXT_PUBLIC_USE_VECTOR_SEARCH=false


# ─── App Meta ──────────────────────────────────────────────────────────────
# 런타임 환경 구분 및 절대 URL 기준점. OAuth 콜백, 이메일 링크 생성 등에 사용.

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development


# ─── Phase 5+ (아직 사용 안 함, 플레이스홀더) ──────────────────────────────
# 해당 Phase 작업 시 실제 값 채울 예정. 지금은 비워둬도 됨.

# Phase 5: 이메일 알림 (Resend)
RESEND_API_KEY=

# Phase 9: 에러 추적 (Sentry)
SENTRY_DSN=

# Phase 9: 분석 (PostHog) — NEXT_PUBLIC_ 접두어 필수 (클라이언트 이벤트 전송)
NEXT_PUBLIC_POSTHOG_KEY=
